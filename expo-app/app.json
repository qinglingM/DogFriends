{
  "expo": {
    "name": "expo-app",
    "slug": "expo-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "需要使用您的位置来查找附近的宠物友好地点",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "需要使用您的位置来查找附近的宠物友好地点",
        "io.expo.AMapAPIKey": "c958a4dca2f7602f3024ca0c139984d3"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "config": {
        "amapApiKey": "c958a4dca2f7602f3024ca0c139984d3"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "@react-native-community/datetimepicker"
    ]
  }
}
