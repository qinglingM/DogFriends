{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "expo-app (React Native + Web)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["start", "--prefix", "expo-app", "--", "--tunnel", "--web"],
      "port": 8081,
      "autoPort": false
